generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id
  role        String  // "spark_user" | "worker"
  name        String
  avatarColor String
  workerId    String? // 6-digit number for workers

  heldPermits                Permit[] @relation("PermitHolder")
  issuedPermits              Permit[] @relation("PermitIssuer")
  signedPoints               IsolationPoint[]
  shifts                     ShiftWorker[]
  
  shiftIsolationConfirmationsIsolated ShiftIsolationConfirmation[] @relation("IsolatedBy")
  shiftIsolationConfirmationsVerified ShiftIsolationConfirmation[] @relation("VerifiedBy")
  
  isolatedTasks IsolationTask[] @relation("IsolatedByTask")
  verifiedTasks IsolationTask[] @relation("VerifiedByTask")
}

model Permit {
  id             String   @id
  type           String   // "CMW" | "CAP_NON_ISOLATION" | "CAP_ISOLATION"
  title          String
  status         String   // "draft" | "isolation_pending" | "active" | "shift_open" | "shift_closed" | "closed"
  permitHolderId String
  permitHolder   User     @relation("PermitHolder", fields: [permitHolderId], references: [id])
  permitIssuerId String
  permitIssuer   User     @relation("PermitIssuer", fields: [permitIssuerId], references: [id])
  closedAt       String?

  isolationTasks              IsolationTask[]
  shifts                      Shift[]
  shiftIsolationConfirmations ShiftIsolationConfirmation[]

  createdAt String
}

model IsolationTask {
  id       String @id
  name     String
  permitId String
  permit   Permit @relation(fields: [permitId], references: [id])

  isolatedById String?
  isolatedBy   User?   @relation("IsolatedByTask", fields: [isolatedById], references: [id])
  isolatedAt   String?
  
  verifiedById String?
  verifiedBy   User?   @relation("VerifiedByTask", fields: [verifiedById], references: [id])
  verifiedAt   String?

  isolationPoints             IsolationPoint[]
  shiftIsolationConfirmations ShiftIsolationConfirmation[]
}

model IsolationPoint {
  id       String  @id
  name     String
  signedBy String?
  signedAt String?
  taskId   String
  task     IsolationTask @relation(fields: [taskId], references: [id])

  signer User? @relation(fields: [signedBy], references: [id])
}

model Shift {
  id                    String  @id
  date                  String
  status                String  // "revalidation_pending" | "open" | "closed"
  permitIssuerSignedOn  Boolean @default(false)
  permitHolderSignedOn  Boolean @default(false)
  permitIssuerSignedOff Boolean @default(false)
  permitHolderSignedOff Boolean @default(false)
  startedAt             String?
  endedAt               String?
  createdAt             String
  permitId              String
  permit                Permit  @relation(fields: [permitId], references: [id])

  workers ShiftWorker[]
}

model ShiftWorker {
  id          String  @id
  userId      String
  user        User    @relation(fields: [userId], references: [id])
  signedOnAt  String
  signedOffAt String?
  shiftId     String
  shift       Shift   @relation(fields: [shiftId], references: [id])
}

model ShiftIsolationConfirmation {
  id              String  @id
  permitId        String
  permit          Permit        @relation(fields: [permitId], references: [id])
  isolationTaskId String
  isolationTask   IsolationTask @relation(fields: [isolationTaskId], references: [id])
  cycleNumber     Int     // 1 = after shift 1 closes, 2 = after shift 2 closes, etc.
  
  isolatedById    String?
  isolatedBy      User?   @relation("IsolatedBy", fields: [isolatedById], references: [id])
  isolatedAt      String?

  verifiedById    String?
  verifiedBy      User?   @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt      String?
}
